# Database — self-hosted Postgres on your VPS (behind PgBouncer for serverless pooling).
# Use the pooled port (e.g. 6432) for the app; keep a direct 5432 URL for migrations.
DATABASE_URL=postgresql://duma:password@your-vps-host:6432/duma?pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://duma:password@your-vps-host:5432/duma

# Native auth (replaces Supabase Auth). MUST be >= 32 random chars. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
AUTH_JWT_SECRET=generate-a-long-random-secret-at-least-32-chars

# Notifications: n8n workflow that delivers customer emails (password reset, welcome, etc.)
N8N_NOTIFICATIONS_WEBHOOK_URL=https://your-n8n-instance.com/webhook/notifications

# Cloudflare R2 (image storage)
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET=duma-images
# Public custom domain connected to the bucket (no trailing slash), e.g. img.yourdomain.com
R2_PUBLIC_DOMAIN=img.yourdomain.com

# n8n Webhook (outbound: app -> n8n)
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/your-webhook-id

# Shared secret n8n must send back on the callback + output-presign endpoints
WEBHOOK_CALLBACK_SECRET=generate-a-long-random-string

# Rate limiting (Upstash Redis — required in production for cross-instance limits)
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
