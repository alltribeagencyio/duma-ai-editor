generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Job {
  id               String    @id @default(uuid())
  userId           String
  status           String    @default("pending")
  prompt           String
  promptType       String
  presetId         String?
  productName      String?
  productCategory  String?
  productSku       String?
  inputImages      String[]
  outputData       String[]  @default([])
  phone            String?
  notifyByEmail    Boolean   @default(true)
  createdAt        DateTime  @default(now())
  startedAt        DateTime?
  completedAt      DateTime?
  errorMessage     String?
  notificationSent Boolean   @default(false)
  parentJobId      String?
  isReEdit         Boolean?  @default(false)
  creditsCost      Int?      @default(1)
  brandPromptId    String?
  creditDeducted   Boolean   @default(false)
  webhookId        String?

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([parentJobId])
  @@index([brandPromptId])
  @@index([isReEdit])
  @@index([creditDeducted])
  @@index([webhookId])
}

model PromptPreset {
  id          String  @id @default(uuid())
  name        String
  description String
  prompt      String
  category    String
  icon        String
  order       Int
  isActive    Boolean @default(true)

  @@index([category])
  @@index([order])
}

model CustomPrompt {
  id          String   @id @default(uuid())
  userId      String
  name        String
  description String
  prompt      String
  category    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([category])
}

model User {
  id                     String    @id @default(uuid())
  email                  String    @unique
  fullName               String?
  phone                  String?
  phoneCountryCode       String?   @default("+254")
  avatar                 String?
  subscriptionTier       String    @default("free")
  subscriptionStatus     String    @default("active")
  subscriptionId         String?
  planId                 String?
  monthlyCredits         Int       @default(10)
  practiceCredits        Int       @default(0)
  creditsUsed            Int       @default(0)
  creditsReset           DateTime? @db.Timestamptz(6)
  brandName              String?
  brandIndustry          String?
  brandAesthetic         String?
  brandColors            String[]
  brandRequirements      String?
  notificationsEmail     Boolean?  @default(true)
  notificationsWhatsApp  Boolean?  @default(false)
  whatsappNumber         String?
  language               String?   @default("en")
  timezone               String?   @default("UTC")
  hasCompletedOnboarding Boolean?  @default(false)
  setupFeesPaid          Boolean?  @default(false)
  onboardingStep         Int?      @default(0)
  createdAt              DateTime? @default(now()) @db.Timestamptz(6)
  updatedAt              DateTime? @default(now()) @updatedAt @db.Timestamptz(6)
  lastLoginAt            DateTime? @db.Timestamptz(6)
  lastActiveAt           DateTime? @db.Timestamptz(6)
  isAdmin                Boolean   @default(false)
  isSuperAdmin           Boolean   @default(false)
  role                   String    @default("user")

  @@index([isAdmin])
  @@index([isSuperAdmin])
}

model BrandPrompt {
  id          String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  createdBy   String
  name        String
  description String
  prompt      String
  category    String
  industry    String?
  isActive    Boolean?  @default(true)
  isDefault   Boolean?  @default(false)
  usageCount  Int?      @default(0)
  createdAt   DateTime? @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime? @default(now()) @updatedAt @db.Timestamptz(6)

  @@index([createdBy])
  @@index([category])
  @@index([industry])
}

model CreditUsage {
  id          String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId      String
  jobId       String?
  amount      Int
  type        String
  description String?
  createdAt   DateTime? @default(now()) @db.Timestamptz(6)

  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

model SubscriptionPlan {
  id                   String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  name                 String    @unique
  displayName          String
  description          String
  price                Int
  currency             String?   @default("NGN")
  monthlyCredits       Int
  maxBrandPrompts      Int
  setupFee             Int?      @default(0)
  paystackPlanCode     String?   @unique
  hasWhatsAppSupport   Boolean?  @default(false)
  hasPrioritySupport   Boolean?  @default(false)
  hasBulkProcessing    Boolean?  @default(false)
  hasAdvancedAnalytics Boolean?  @default(false)
  hasCustomBranding    Boolean?  @default(false)
  isActive             Boolean?  @default(true)
  createdAt            DateTime? @default(now()) @db.Timestamptz(6)
  updatedAt            DateTime? @default(now()) @updatedAt @db.Timestamptz(6)

  @@index([name])
  @@index([isActive])
}

model Subscription {
  id                       String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId                   String    @unique
  planId                   String
  paystackCustomerCode     String?
  paystackSubscriptionCode String?   @unique
  paystackAuthCode         String?
  status                   String?   @default("active")
  currentPeriodStart       DateTime  @db.Timestamptz(6)
  currentPeriodEnd         DateTime  @db.Timestamptz(6)
  cancelAtPeriodEnd        Boolean?  @default(false)
  canceledAt               DateTime? @db.Timestamptz(6)
  setupFeePaid             Boolean?  @default(false)
  setupFeeAmount           Int?
  setupFeePaidAt           DateTime? @db.Timestamptz(6)
  createdAt                DateTime? @default(now()) @db.Timestamptz(6)
  updatedAt                DateTime? @default(now()) @updatedAt @db.Timestamptz(6)

  @@index([userId])
  @@index([status])
  @@index([paystackSubscriptionCode])
}

model Payment {
  id                    String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId                String
  subscriptionId        String?
  paystackReference     String    @unique
  paystackTransactionId String?
  amount                Int
  currency              String?   @default("NGN")
  status                String
  type                  String
  description           String?
  metadata              Json?
  paidAt                DateTime? @db.Timestamptz(6)
  createdAt             DateTime? @default(now()) @db.Timestamptz(6)

  @@index([userId])
  @@index([paystackReference])
  @@index([status])
  @@index([type])
}

model UserWebhook {
  id              String   @id @default(uuid())
  userId          String
  name            String
  webhookUrl      String
  isActive        Boolean  @default(false)
  priority        Int      @default(0)
  webhookType     String   @default("image_processing")
  tierRestriction String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([isActive])
  @@index([webhookType])
}

model BrandPromptAssignment {
  id            String   @id @default(uuid())
  brandPromptId String
  userId        String
  assignedBy    String
  createdAt     DateTime @default(now())

  @@unique([brandPromptId, userId])
  @@index([userId])
  @@index([brandPromptId])
}

model WorkflowLog {
  id              String    @id @default(uuid())
  userId          String
  jobId           String?
  webhookId       String?
  workflowType    String
  executionId     String?
  executionUrl    String?
  status          String
  requestPayload  Json?
  responsePayload Json?
  errorMessage    String?
  duration        Int?
  createdAt       DateTime  @default(now())
  completedAt     DateTime?

  @@index([userId])
  @@index([jobId])
  @@index([workflowType])
  @@index([status])
  @@index([createdAt])
}

model SupportTicket {
  id              String    @id @default(uuid())
  userId          String
  userEmail       String
  userName        String?
  subject         String
  message         String
  category        String
  priority        String    @default("normal")
  status          String    @default("open")
  assignedTo      String?
  n8nExecutionId  String?
  internalNotes   String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  resolvedAt      DateTime?

  @@index([userId])
  @@index([status])
  @@index([category])
  @@index([createdAt])
}

model AdminLog {
  id         String   @id @default(uuid())
  adminId    String
  action     String
  targetType String?
  targetId   String?
  details    Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([adminId])
  @@index([action])
  @@index([createdAt])
}
