// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Job {
  id           String    @id @default(uuid())
  userId       String

  // Job Data
  status       String    @default("pending") // pending, processing, completed, failed
  prompt       String
  promptType   String    // "preset", "custom", "brand"
  presetId     String?
  brandPromptId String?  // Link to brand prompt if used

  // Re-editing & Versions
  parentJobId    String?   // Link to original job for re-edits
  isReEdit       Boolean   @default(false)
  creditsCost    Int       @default(1)

  // Product Information
  productName     String?
  productCategory String?
  productSku      String?

  // Images
  inputImages  String[]
  outputData   Json?     // [{image: base64, driveLink: url, downloadUrl: url}]

  // Contact
  phone        String?
  notifyByEmail Boolean  @default(true)

  // Metadata
  createdAt      DateTime  @default(now())
  startedAt      DateTime?
  completedAt    DateTime?
  errorMessage   String?

  // Notification
  notificationSent Boolean @default(false)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([parentJobId])
}

model PromptPreset {
  id          String  @id @default(uuid())
  name        String
  description String
  prompt      String
  category    String  // "background", "enhancement", "focus"
  icon        String  // lucide icon name
  order       Int
  isActive    Boolean @default(true)

  @@index([category])
  @@index([order])
}

model CustomPrompt {
  id          String   @id @default(uuid())
  userId      String
  name        String
  description String
  prompt      String
  category    String   // "background", "enhancement", "focus", "other"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([category])
}

model User {
  id              String   @id @default(uuid())
  email           String   @unique
  name            String?
  phone           String?
  avatar          String?

  // Subscription & Billing
  subscriptionTier    String   @default("free")        // free, starter, pro, enterprise
  subscriptionStatus  String   @default("active")      // active, canceled, past_due, trialing
  subscriptionId      String?                          // Paystack subscription ID
  planId              String?                          // Paystack plan ID

  // Credits
  monthlyCredits      Int      @default(0)             // Monthly allocation
  practiceCredits     Int      @default(0)             // One-time practice credits
  creditsUsed         Int      @default(0)             // Total credits consumed
  creditsReset        DateTime?                        // Next reset date

  // Brand & Preferences
  brandName           String?
  brandIndustry       String?
  brandAesthetic      String?
  brandColors         String[]                         // Array of color preferences
  brandRequirements   String?                          // Custom brand requirements text

  // Settings
  notificationsEmail     Boolean @default(true)
  notificationsWhatsApp  Boolean @default(false)
  whatsappNumber         String?
  language               String  @default("en")
  timezone               String  @default("UTC")

  // Setup & Onboarding
  hasCompletedOnboarding Boolean @default(false)
  setupFeesPaid          Boolean @default(false)
  onboardingStep         Int     @default(0)

  // Metadata
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  lastLoginAt     DateTime?
  lastActiveAt    DateTime?

  @@index([email])
  @@index([subscriptionTier])
  @@index([subscriptionStatus])
}

model BrandPrompt {
  id          String   @id @default(uuid())
  userId      String
  name        String
  description String
  prompt      String
  category    String   // "background", "enhancement", "focus", "brand"
  industry    String?  // Target industry
  isActive    Boolean  @default(true)
  usageCount  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([category])
  @@index([industry])
}

model CreditUsage {
  id          String   @id @default(uuid())
  userId      String
  jobId       String?  // Link to Job if applicable
  amount      Int      // Credits consumed
  type        String   // "upload", "re_edit", "upscale", "bulk", "manual_adjustment"
  description String?  // Human readable description
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

model SubscriptionPlan {
  id              String  @id @default(uuid())
  name            String  @unique // "free", "starter", "pro", "enterprise"
  displayName     String  // "Starter Plan"
  description     String  // Plan description
  price           Int     // Price in kobo (Paystack uses kobo)
  currency        String  @default("NGN")

  // Features
  monthlyCredits  Int     // Credits per month
  maxBrandPrompts Int     // Brand prompts limit
  setupFee        Int     @default(0) // One-time setup fee

  // Paystack Integration
  paystackPlanCode String? @unique // Paystack plan code

  // Features flags
  hasWhatsAppSupport   Boolean @default(false)
  hasPrioritySupport   Boolean @default(false)
  hasBulkProcessing    Boolean @default(false)
  hasAdvancedAnalytics Boolean @default(false)
  hasCustomBranding    Boolean @default(false)

  isActive        Boolean @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([name])
  @@index([isActive])
}

model Subscription {
  id                    String   @id @default(uuid())
  userId                String   @unique
  planId                String

  // Paystack Integration
  paystackCustomerCode  String?  // Paystack customer code
  paystackSubscriptionCode String? @unique // Paystack subscription code
  paystackAuthCode      String?  // Payment authorization code

  status                String   @default("active") // active, canceled, past_due, trialing, incomplete
  currentPeriodStart    DateTime
  currentPeriodEnd      DateTime
  cancelAtPeriodEnd     Boolean  @default(false)
  canceledAt            DateTime?

  // Setup fees
  setupFeePaid          Boolean  @default(false)
  setupFeeAmount        Int?
  setupFeePaidAt        DateTime?

  // Metadata
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([paystackSubscriptionCode])
}

model Payment {
  id                  String   @id @default(uuid())
  userId              String
  subscriptionId      String?

  // Paystack Integration
  paystackReference   String   @unique
  paystackTransactionId String?

  amount              Int      // Amount in kobo
  currency            String   @default("NGN")
  status              String   // success, failed, pending, abandoned
  type                String   // subscription, setup_fee, credit_purchase, manual
  description         String?

  // Metadata
  metadata            Json?    // Additional payment metadata
  paidAt              DateTime?
  createdAt           DateTime @default(now())

  @@index([userId])
  @@index([paystackReference])
  @@index([status])
  @@index([type])
}
